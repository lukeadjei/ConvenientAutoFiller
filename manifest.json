{
  "manifest_version": 3,
  "name": "AutoFiller",
  "version": "1.0",
  "description": "Auto-fills saved credentials on configured login pages",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://shib.idm.umd.edu/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://shib.idm.umd.edu/*"],
      "js": ["config/sites.js", "content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
